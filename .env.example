# --- shared ---
NODE_ENV=development

# --- database ---
DATABASE_URL="postgresql://soccerx:soccerx@localhost:5432/soccerx?schema=soccerx"

# --- redis (BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- auth: Clerk (Google enabled inside Clerk dashboard) ---
# Grab keys at https://dashboard.clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login

# --- football data API (api-football via RapidAPI / api-sports.io) ---
# Free tier: https://www.api-football.com/pricing  (100 req/day)
FOOTBALL_API_KEY=""
FOOTBALL_API_BASE_URL="https://v3.football.api-sports.io"
FOOTBALL_API_HOST="v3.football.api-sports.io"

# --- web ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- api ---
API_PORT=4000
API_CORS_ORIGINS="http://localhost:3000"

# --- worker ---
SCORING_POLL_INTERVAL_MS=300000
LEADERBOARD_REFRESH_INTERVAL_MS=60000
