# --- shared ---
NODE_ENV=development

# --- database ---
DATABASE_URL="postgresql://soccerx:soccerx@localhost:5432/soccerx?schema=soccerx"

# --- redis (BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- clerk (auth) ---
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# --- football data API ---
# Pick one: api-football.com | football-data.org | sportmonks.com
FOOTBALL_API_KEY=""
FOOTBALL_API_BASE_URL="https://api.football-data.org/v4"

# --- web ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- api ---
API_PORT=4000
API_CORS_ORIGINS="http://localhost:3000"

# --- worker ---
SCORING_POLL_INTERVAL_MS=300000
LEADERBOARD_REFRESH_INTERVAL_MS=60000
