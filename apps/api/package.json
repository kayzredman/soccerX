    "drizzle-orm": "^0.36.0",
    "fastify": "^5.8.5",
    "nanoid": "^5.1.11",
    "postgres": "^3.4.5",
    "tsx": "^4.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "typescript": "^5.6.0"
  }
}
